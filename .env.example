# ══════════════════════════════════════════════
#  invest-nongtearngon  |  .env configuration
#  copy ไฟล์นี้เป็น .env แล้วกรอกค่าของคุณ
# ══════════════════════════════════════════════

# ── พอร์ต (บาท) ───────────────────────────────
PORTFOLIO_THB=5000

# ── Telegram Bot ─────────────────────────────
# (LINE Notify ปิดแล้ว 31 มี.ค. 2025 — ใช้ Telegram แทน)
#
# ขั้นตอน:
# 1. เปิด Telegram → ค้นหา @BotFather → พิมพ์ /newbot
# 2. ตั้งชื่อ bot เช่น "Invest Nong Tearngon"
# 3. BotFather จะให้ token เช่น  1234567890:ABCDEFxxxxxxx
# 4. เปิด bot ที่สร้าง → กด Start
# 5. ค้นหา @userinfobot → กด Start → copy "Id:" ตัวเลข
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── Webull Paper Trading ──────────────────────
# สมัครฟรีที่ https://www.webull.com/
# เลือก Paper Trading (ไม่ต้องใช้เงินจริง)
WEBULL_EMAIL=อีเมล_webull_ของคุณ
WEBULL_PASSWORD=รหัสผ่าน_webull
WEBULL_TRADE_PIN=6_หลัก_trading_pin

# ── Alpaca (ถ้าใช้) ───────────────────────────
# สมัครฟรีที่ https://alpaca.markets/
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE=false

# ── Email (ถ้าใช้) ────────────────────────────
# Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_SENDER=อีเมล_gmail@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_RECIPIENT=6442262@schoolptk.ac.th
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
